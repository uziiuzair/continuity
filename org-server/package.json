{
  "name": "continuity-org-server",
  "version": "0.1.0",
  "description": "Self-hostable HTTP server that stores and serves shared organization memories for Continuity. Complements the continuity-org-memory-sync plugin.",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "continuity",
    "memory",
    "org",
    "sync",
    "mcp",
    "sqlite",
    "self-hosted"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "better-sqlite3": "^11.9.1",
    "fastify": "^5.2.1",
    "zod": "^3.25.17"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8"
  }
}
